@model IEnumerable<Tenis3t.Models.Venta>

@{
    ViewData["Title"] = "Ventas";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Historial de Ventas</h2>

    <!-- Mensajes de alerta -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-auto" style="max-width: 1000px;" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-auto" style="max-width: 1000px;" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Filtros de búsqueda mejorados -->
    <div class="card mb-4 mx-auto" style="max-width: 1000px;">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3" id="filtroForm">
                <!-- Filtro por nombre de cliente -->
                <div class="col-md-3">
                    <label for="nombreCliente" class="form-label">Nombre del Cliente</label>
                    <input type="text" name="nombreCliente" id="nombreCliente" class="form-control"
                        value="@Context.Request.Query["nombreCliente"]" placeholder="Buscar cliente...">
                </div>

                <!-- Selector de tipo de filtro -->
                <div class="col-md-2">
                    <label for="tipoFiltro" class="form-label">Filtrar por</label>
                    <select name="tipoFiltro" id="tipoFiltro" class="form-select"
                        onchange="cambiarTipoFiltro(this.value)">
                        <option value="dia" selected="@(Context.Request.Query["tipoFiltro"] == "dia")">Día específico
                        </option>
                        <option value="mes" selected="@(Context.Request.Query["tipoFiltro"] == "mes")">Mes</option>
                        <option value="rango" selected="@(Context.Request.Query["tipoFiltro"] == "rango")">Rango de
                            fechas</option>
                    </select>
                </div>

                <!-- Filtro por día específico -->
                <div class="col-md-3" id="filtroDia">
                    <label for="fechaFiltro" class="form-label">Fecha específica</label>
                    <input type="date" name="fechaFiltro" id="fechaFiltro" class="form-control"
                        value="@Context.Request.Query["fechaFiltro"]">
                </div>

                <!-- Filtro por mes -->
                <div class="col-md-3 d-none" id="filtroMes">
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label for="mesFiltro" class="form-label">Mes</label>
                            <select name="mesFiltro" id="mesFiltro" class="form-select">
                                <option value="">Seleccione...</option>
                                <option value="1" selected="@(Context.Request.Query["mesFiltro"] == "1")">Enero</option>
                                <option value="2" selected="@(Context.Request.Query["mesFiltro"] == "2")">Febrero
                                </option>
                                <option value="3" selected="@(Context.Request.Query["mesFiltro"] == "3")">Marzo</option>
                                <option value="4" selected="@(Context.Request.Query["mesFiltro"] == "4")">Abril</option>
                                <option value="5" selected="@(Context.Request.Query["mesFiltro"] == "5")">Mayo</option>
                                <option value="6" selected="@(Context.Request.Query["mesFiltro"] == "6")">Junio</option>
                                <option value="7" selected="@(Context.Request.Query["mesFiltro"] == "7")">Julio</option>
                                <option value="8" selected="@(Context.Request.Query["mesFiltro"] == "8")">Agosto
                                </option>
                                <option value="9" selected="@(Context.Request.Query["mesFiltro"] == "9")">Septiembre
                                </option>
                                <option value="10" selected="@(Context.Request.Query["mesFiltro"] == "10")">Octubre
                                </option>
                                <option value="11" selected="@(Context.Request.Query["mesFiltro"] == "11")">Noviembre
                                </option>
                                <option value="12" selected="@(Context.Request.Query["mesFiltro"] == "12")">Diciembre
                                </option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="anioFiltro" class="form-label">Año</label>
                            <select name="anioFiltro" id="anioFiltro" class="form-select">
                                <option value="">Seleccione...</option>
                                @foreach (var año in ViewBag.AñosDisponibles as List<int>)
                                {
                                    <option value="@año"
                                        selected="@(Context.Request.Query["anioFiltro"] == año.ToString())">@año</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Filtro por rango de fechas -->
                <div class="col-md-3 d-none" id="filtroRango">
                    <label for="fechaFiltroRango" class="form-label">Rango de fechas</label>
                    <input type="text" name="fechaFiltro" id="fechaFiltroRango" class="form-control"
                        value="@Context.Request.Query["fechaFiltro"]" placeholder="Ej: 01/01/2023 a 31/12/2023"
                        autocomplete="off">
                </div>

                <!-- Botones mejorados -->
                <div class="col-md-1 d-flex align-items-end">
                    <div class="d-flex gap-2 w-100">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-search"></i> Buscar
                        </button>
                        <a asp-action="Create" class="btn btn-success flex-grow-1">
                            <i class="bi bi-plus-circle"></i> Nueva venta
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Listado de ventas -->
    <div class="accordion mx-auto" id="ventasAccordion" style="max-width: 1000px;">
        @foreach (var venta in Model)
        {
            <div class="accordion-item mb-3 border rounded">
                <h2 class="accordion-header" id="heading-@venta.Id">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapse-@venta.Id" aria-expanded="false" aria-controls="collapse-@venta.Id">
                        <div class="d-flex justify-content-between w-100">
                            <span class="fw-bold">Venta #@venta.Id</span>
                            <span class="text-muted me-3">@venta.FechaVenta.ToString("dd/MM/yyyy")</span>
                            <span class="badge bg-primary">Total: @venta.Total.ToString("C")</span>
                        </div>
                    </button>
                </h2>
                <div id="collapse-@venta.Id" class="accordion-collapse collapse" aria-labelledby="heading-@venta.Id"
                    data-bs-parent="#ventasAccordion">
                    <div class="accordion-body">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <p><strong>Cliente:</strong> @(venta.NombreCliente ?? "Público general")</p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Fecha:</strong> @venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="col-md-4">
                                <p><strong>Estado:</strong>
                                    <span class="badge @(venta.Estado == "Completada" ? "bg-success" : "bg-danger")">
                                        @venta.Estado
                                    </span>
                                </p>
                            </div>
                        </div>

                        <h5 class="mb-3">Productos Vendidos</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th>Talla</th>
                                        <th>Cantidad</th>
                                        <th>Precio Unitario</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var detalle in venta.Detalles)
                                    {
                                        <tr>
                                            <td>@detalle.TallaInventario?.Inventario?.Nombre</td>
                                            <td>@detalle.TallaInventario?.Talla</td>
                                            <td>@detalle.Cantidad</td>
                                            <td>@detalle.PrecioUnitario.ToString("C")</td>
                                            <td>@((detalle.Cantidad * detalle.PrecioUnitario).ToString("C"))</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" class="text-end fw-bold">Subtotal:</td>
                                        <td class="fw-bold">@venta.Detalles.Sum(d => d.PrecioUnitario *
                                                                                    d.Cantidad).ToString("C")</td>
                                </tr>
                                @if (venta.Descuento > 0)
                                    {
                                        <tr>
                                            <td colspan="4" class="text-end fw-bold">Descuento (@venta.Descuento%):</td>
                                            <td class="fw-bold text-danger">@venta.Detalles.Sum(d => d.PrecioUnitario *
                                                                                        d.Cantidad) * venta.Descuento / 100).ToString("C")</td>
                                </tr>
                                                                }
                                    <tr>
                                        <td colspan="4" class="text-end fw-bold">Total:</td>
                                        <td class="fw-bold">@venta.Total.ToString("C")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Sección de métodos de pago -->
                        <h5 class="mb-3 mt-4">Métodos de Pago</h5>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Método</th>
                                        <th>Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pago in venta.Pagos)
                                    {
                                        <tr>
                                            <td>@pago.MetodoPago?.Nombre</td>
                                            <td>@pago.Monto.ToString("C")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td class="text-end fw-bold">Total Pagado:</td>
                                        <td class="fw-bold">@venta.Pagos.Sum(p => p.Monto).ToString("C")</td>
                                    </tr>
                                    @{
                                        var saldoPendiente = venta.Total - venta.Pagos.Sum(p => p.Monto);
                                    }
                                    @if (saldoPendiente > 0)
                                    {
                                        <tr>
                                            <td class="text-end fw-bold text-danger">Saldo Pendiente:</td>
                                            <td class="fw-bold text-danger">@saldoPendiente.ToString("C")</td>
                                        </tr>
                                    }
                                    else if (saldoPendiente < 0)
                                    {
                                        <tr>
                                            <td class="text-end fw-bold text-warning">Cambio:</td>
                                            <td class="fw-bold text-warning">@Math.Abs(saldoPendiente).ToString("C")</td>
                                        </tr>
                                    }
                                </tfoot>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end mt-3">
                            <a asp-action="Details" asp-route-id="@venta.Id" class="btn btn-info btn-sm me-2">
                                <i class="bi bi-eye"></i> Detalles
                            </a>
                            @if (venta.Estado == "Completada")
                            {
                                <a asp-action="Edit" asp-route-id="@venta.Id" class="btn btn-warning btn-sm me-2">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <button type="button" class="btn btn-danger btn-sm me-2" data-bs-toggle="modal"
                                    data-bs-target="#deleteModal-@venta.Id">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            }
                            <a asp-action="Print" asp-route-id="@venta.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-printer"></i> Imprimir
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal para confirmar eliminación -->
            <div class="modal fade" id="deleteModal-@venta.Id" tabindex="-1" aria-labelledby="deleteModalLabel"
                aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title" id="deleteModalLabel">Eliminar Venta</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                        </div>
                        <form asp-action="Delete" method="post">
                            <div class="modal-body">
                                <p>¿Está seguro que desea eliminar la venta #@venta.Id?</p>
                                <p class="text-danger"><small>Esta acción no se puede deshacer.</small></p>
                                <input type="hidden" name="id" value="@venta.Id" />
                                <div class="mb-3">
                                    <label for="claveSeguridad" class="form-label">Clave de Seguridad</label>
                                    <input type="password" class="form-control" id="claveSeguridad" name="claveSeguridad"
                                        required />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                <button type="submit" class="btn btn-danger">Confirmar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<!-- Script para inicialización -->
@section Scripts {
    <script>
        // Inicializar los filtros según el tipo seleccionado
        document.addEventListener('DOMContentLoaded', function () {
            // Obtener el tipo de filtro actual
            const tipoFiltro = document.getElementById('tipoFiltro').value;
            cambiarTipoFiltro(tipoFiltro);

            // Inicializar datepicker para el rango de fechas
            $('#fechaFiltroRango').daterangepicker({
                locale: {
                    format: 'DD/MM/YYYY',
                    separator: ' a ',
                    applyLabel: 'Aplicar',
                    cancelLabel: 'Cancelar',
                    fromLabel: 'De',
                    toLabel: 'A',
                    daysOfWeek: ['Do', 'Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sa'],
                    monthNames: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
                        'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'],
                    firstDay: 1
                },
                opens: 'right',
                autoUpdateInput: true,
                showDropdowns: true,
                autoApply: false,
                alwaysShowCalendars: true,
                startDate: moment().subtract(29, 'days'),
                endDate: moment()
            });

            // Manejar el evento de aplicación del rango
            $('#fechaFiltroRango').on('apply.daterangepicker', function (ev, picker) {
                $(this).val(picker.startDate.format('DD/MM/YYYY') + ' a ' + picker.endDate.format('DD/MM/YYYY'));
                $('#filtroForm').submit();
            });

            // Limpiar el campo cuando se cancela
            $('#fechaFiltroRango').on('cancel.daterangepicker', function (ev, picker) {
                $(this).val('');
                $('#filtroForm').submit();
            });

            // Cierra automáticamente los mensajes de alerta después de 5 segundos
            setTimeout(function () {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function (alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });

        function cambiarTipoFiltro(tipo) {
            // Ocultar todos los filtros
            document.getElementById('filtroDia').classList.add('d-none');
            document.getElementById('filtroMes').classList.add('d-none');
            document.getElementById('filtroRango').classList.add('d-none');

            // Mostrar solo el filtro seleccionado
            if (tipo === 'dia') {
                document.getElementById('filtroDia').classList.remove('d-none');
            } else if (tipo === 'mes') {
                document.getElementById('filtroMes').classList.remove('d-none');
            } else if (tipo === 'rango') {
                document.getElementById('filtroRango').classList.remove('d-none');
            }
        }
    </script>

}

<style>
    .accordion-button:not(.collapsed) {
        background-color: #f8f9fa;
        color: #212529;
    }

    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(0, 0, 0, .125);
    }

    .accordion-item {
        border-radius: 0.25rem !important;
    }

    .badge.bg-success {
        background-color: #198754 !important;
    }

    .badge.bg-danger {
        background-color: #dc3545 !important;
    }
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
<!-- DateRangePicker -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
<script type="text/javascript" src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>